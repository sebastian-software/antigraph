{
  "name": "antigraph",
  "version": "0.1.2",
  "description": "OCR-based pipeline that turns Kindle books you own into clean, chapter-scoped Markdown.",
  "author": "Sebastian Werner <s.werner@sebastian-software.de>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sebastian-software/antigraph.git"
  },
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "main": "./dist/public-api.js",
  "types": "./dist/public-api.d.ts",
  "exports": {
    ".": {
      "types": "./dist/public-api.d.ts",
      "import": "./dist/public-api.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "antigraph": "./dist/cli.js"
  },
  "files": [
    "dist",
    "license",
    "readme.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "cli": "tsx src/cli.ts",
    "compare": "tsx src/cli.ts compare",
    "pack:smoke": "node scripts/smoke-pack.mjs",
    "prepack": "pnpm build",
    "prepublishOnly": "pnpm test && pnpm test:coverage && pnpm build && publint && pnpm pack:smoke",
    "test": "run-s test:format test:lint test:typecheck test:unit",
    "test:coverage": "vitest run --coverage",
    "test:format": "prettier --check \"**/*.{js,ts,tsx}\"",
    "test:lint": "eslint . --max-warnings=0",
    "test:typecheck": "tsc --noEmit",
    "test:unit": "vitest run",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "citty": "^0.2.2",
    "p-race": "^3.1.0",
    "patchright": "^1.59.4",
    "sharp": "^0.34.5",
    "tar": "^7.5.13"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "4.1.5",
    "eslint": "^10.2.1",
    "eslint-config-setup": "^0.4.0",
    "lint-staged": "^17.0.4",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.3",
    "publint": "^0.3.18",
    "simple-git-hooks": "^2.13.1",
    "tsdown": "^0.22.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "4.1.5"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --ignore-unknown --write",
      "eslint --cache --fix"
    ]
  }
}
